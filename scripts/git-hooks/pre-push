#!/usr/bin/env bash
# Auto-bump VERSION (patch) on every push and commit it.
# First push is aborted after the bump commit; run git push again to publish.
set -euo pipefail

if [ "${SKIP_VERSION_BUMP:-}" = "1" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

has_branch_update=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_ref:-}" ] && continue
  case "$local_ref" in
    refs/heads/*|HEAD) has_branch_update=1 ;;
  esac
done
if [ "$has_branch_update" -eq 0 ]; then
  exit 0
fi

if ! git diff --cached --quiet; then
  echo "pre-push: staged changes present; skipping auto version bump." >&2
  exit 0
fi

# Skip if the tip commit is already a version bump (second push after bump).
if git log -1 --pretty=%s | grep -qE '^chore: bump version to '; then
  exit 0
fi

before="$(tr -d '[:space:]' < VERSION)"
next="$("$ROOT/scripts/bump-version.sh")"
git add VERSION frontend-react/package.json

if git diff --cached --quiet; then
  exit 0
fi

git commit -m "chore: bump version to ${next}"

cat >&2 <<EOF

Version bumped: ${before} -> ${next}
Run git push again to publish (includes the version commit).

EOF
exit 1

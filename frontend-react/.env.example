# Local dev (default): Vite proxies /api to Laravel on port 8000
VITE_API_BASE=/api

# LAN testing from other devices on the same network — use your machine IP:
# VITE_API_BASE=http://10.110.4.223:8000/api

# Production (okusoma.com frontend → api.mainmarket.org backend):
# VITE_API_BASE=https://api.mainmarket.org/api

# Production (same-origin nginx /api proxy on okusoma.com):
# VITE_API_BASE=/api
